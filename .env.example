# Configuración de SMTP para SolbaBackups
# Copia este archivo como .env y rellena tus credenciales.

# ── SMTP (correo del remitente de Solba) ─────────────────────────────────────
SOLBA_SMTP_HOST=smtp.gmail.com
SOLBA_SMTP_PORT=587
SOLBA_SMTP_USER=tu-usuario@gmail.com
SOLBA_SMTP_PASS=tu-contraseña-de-aplicación

# ── WhatsApp (ApiWhatsApp REST Outbox) ───────────────────────────────────────
# URL base del microservicio ApiWhatsApp (local en desarrollo, producción de Solba en produccion)
WHATSAPP_API_URL=http://localhost:8000

# Número de teléfono destino en formato E.164 sin '+' (ej: 34622430735)
WHATSAPP_PHONE=34622430735

# Activar/desactivar notificaciones WhatsApp sin tocar código (true | false)
WHATSAPP_ENABLED=false

# Nombre del template registrado en Meta Business Manager
WHATSAPP_TEMPLATE=solba_backup_status

# Código de idioma del template
WHATSAPP_LANGUAGE=es_ES

# Timeout de la petición HTTP a ApiWhatsApp (en segundos)
WHATSAPP_TIMEOUT=5

