# ============================================================
# ApiWhatsApp — Plantilla de Variables de Entorno
# Copia este archivo como .env y rellena tus credenciales.
# NUNCA subas el archivo .env real a Git.
# ============================================================

# --- Base de Datos PostgreSQL ---
# Formato: postgresql+asyncpg://usuario:contraseña@host:puerto/nombre_bd
DATABASE_URL=postgresql+asyncpg://usuario:contraseña@localhost:5432/whatsapp_outbox

# --- Proveedor de WhatsApp ---
# Valores posibles: 'META' (Cloud API oficial) | 'WAHA' (WhatsApp Web automatizado)
WHATSAPP_PROVIDER=META

# --- Meta WhatsApp Cloud API ---
# Obtenlas desde: https://developers.facebook.com/apps/
# Solo necesario si WHATSAPP_PROVIDER=META
META_PHONE_NUMBER_ID=123456789012345
META_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxx...
META_API_VERSION=v19.0

# --- WAHA (WhatsApp HTTP API via Docker) ---
# Solo necesario si WHATSAPP_PROVIDER=WAHA
# URL base del contenedor WAHA (por defecto interno a Docker Compose)
WHATSAPP_WEB_API_URL=http://waha:3000/api

# --- Comportamiento del Worker ---
# Máximo de reintentos antes de marcar un mensaje como FAILED definitivamente
WORKER_MAX_RETRIES=3

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
